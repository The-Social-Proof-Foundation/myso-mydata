FROM grafana/mimir:latest

# Copy custom configuration
COPY mimir-railway.yaml /etc/mimir/config.yaml

# Expose ports
EXPOSE 9009 9095

# Set working directory
WORKDIR /etc/mimir

# Run Mimir (distroless image has no shell; GCP creds via GCP_SERVICE_ACCOUNT_JSON env + config expand)
CMD ["-config.file=/etc/mimir/config.yaml", "-config.expand-env=true"]
